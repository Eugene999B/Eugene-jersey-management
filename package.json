{
  "name": "sports-shop-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/prepare-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx prisma/seed.ts --demo",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "docs:generate": "tsx scripts/generate-docs.ts",
    "docs:handoff": "tsx scripts/generate-handoff-doc.ts",
    "jobs:release-reservations": "tsx scripts/release-expired-reservations.ts",
    "setup:demo": "prisma generate && prisma db push && tsx prisma/seed.ts --demo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "papaparse": "^5.5.4",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@hono/node-server": "^2.0.5",
    "fast-uri": "^3.1.4",
    "postcss": "^8.5.10",
    "sharp": "^0.35.3",
    "uuid": "^11.1.1"
  }
}
