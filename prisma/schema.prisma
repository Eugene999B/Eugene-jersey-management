generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum PlanTier {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
  DESIGNER
  INVENTORY_CLERK
  ACCOUNTANT
  VIEWER
}

enum AttributeType {
  TEXT
  NUMBER
  SELECT
}

enum ProductCondition {
  NEW
  USED
  REFURBISHED
}

enum OrderStatus {
  PENDING
  IN_PRODUCTION
  READY
  COMPLETED
  CANCELLED
}

enum OrderChannel {
  POS
  ONLINE
}

enum PaymentMethod {
  CASH
  CARD
  MOMO
  STORE_CREDIT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum NotificationChannel {
  IN_APP
  SMS
  WHATSAPP
  EMAIL
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  READ
}

model Shop {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  primaryColor   String   @default("#0f766e")
  secondaryColor String   @default("#f97316")
  planTier       PlanTier @default(BASIC)
  isActive       Boolean  @default(true)
  city           String?
  country        String?  @default("Ghana")
  currency       String   @default("GHS")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users              User[]
  categories         Category[]
  attributeTemplates AttributeTemplate[]
  products           Product[]
  customers          Customer[]
  orders             Order[]
  auditLogs          AuditLog[]
  invites            InviteToken[]
  announcements      Announcement[]
  holds              SaleHold[]
  notifications      Notification[]
  paymentConfig      ShopPaymentConfig?

  @@index([isActive, planTier])
}

model User {
  id               String    @id @default(cuid())
  shopId           String?
  email            String    @unique
  passwordHash     String
  name             String
  phone            String?
  role             Role
  isActive         Boolean   @default(true)
  failedLoginCount Int       @default(0)
  lockUntil        DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  shop                   Shop?                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  auditLogs              AuditLog[]
  invitesSent            InviteToken[]           @relation("InviteCreatedBy")
  passwordResets         PasswordResetToken[]
  announcementDismissals AnnouncementDismissal[]
  processedOrders        Order[]                 @relation("OrderProcessedBy")
  notifications          Notification[]

  @@index([shopId, id])
  @@index([role, isActive])
}

model Category {
  id                  String   @id @default(cuid())
  shopId              String
  name                String
  parentCategoryId    String?
  attributeTemplateId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  parent            Category?          @relation("CategoryTree", fields: [parentCategoryId], references: [id])
  children          Category[]         @relation("CategoryTree")
  attributeTemplate AttributeTemplate? @relation(fields: [attributeTemplateId], references: [id])
  products          Product[]

  @@unique([shopId, name])
  @@index([shopId, id])
}

model AttributeTemplate {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop       Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  fields     AttributeField[]
  categories Category[]

  @@unique([shopId, name])
  @@index([shopId, id])
}

model AttributeField {
  id         String        @id @default(cuid())
  templateId String
  name       String
  type       AttributeType
  options    Json?
  required   Boolean       @default(false)

  template AttributeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Product {
  id                  String           @id @default(cuid())
  shopId              String
  categoryId          String
  name                String
  description         String?
  brand               String?
  condition           ProductCondition @default(NEW)
  isPersonalizable    Boolean          @default(false)
  isService           Boolean          @default(false)
  isRentable          Boolean          @default(false)
  basePrice           Decimal          @db.Decimal(12, 2)
  dailyRentalRate     Decimal?         @db.Decimal(12, 2)
  serviceDurationMins Int?
  lowStockThreshold   Int              @default(5)
  images              Json             @default("[]")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]

  @@index([shopId, id])
  @@index([shopId, categoryId])
  @@index([shopId, condition])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  sku           String   @unique
  attributes    Json     @default("{}")
  stockQty      Int      @default(0)
  priceOverride Decimal? @db.Decimal(12, 2)
  barcode       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId, id])
  @@index([sku])
}

model Customer {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  email         String?
  phone         String?
  group         String   @default("Retail")
  notes         String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([shopId, id])
  @@index([shopId, phone])
}

model Order {
  id             String       @id @default(cuid())
  shopId         String
  customerId     String?
  processedById  String?
  status         OrderStatus  @default(PENDING)
  channel        OrderChannel @default(POS)
  totalAmount    Decimal      @db.Decimal(12, 2)
  discountAmount Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal      @default(0) @db.Decimal(12, 2)
  notes          String?
  rush           Boolean      @default(false)
  receiptNumber  String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  shop        Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer    Customer?   @relation(fields: [customerId], references: [id])
  processedBy User?       @relation("OrderProcessedBy", fields: [processedById], references: [id])
  items       OrderItem[]
  payments    Payment[]

  @@index([shopId, id])
  @@index([shopId, status])
  @@index([shopId, createdAt])
}

model OrderItem {
  id                  String  @id @default(cuid())
  orderId             String
  productVariantId    String
  quantity            Int
  unitPrice           Decimal @db.Decimal(12, 2)
  personalizationData Json?

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  method            PaymentMethod
  amount            Decimal       @db.Decimal(12, 2)
  status            PaymentStatus @default(PENDING)
  providerReference String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model InviteToken {
  id          String    @id @default(cuid())
  shopId      String
  email       String
  role        Role
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  shop      Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdBy User @relation("InviteCreatedBy", fields: [createdById], references: [id])

  @@index([shopId, id])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String   @id @default(cuid())
  shopId    String?
  title     String
  body      String
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())

  shop       Shop?                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  dismissals AnnouncementDismissal[]
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  dismissedAt    DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

model SaleHold {
  id        String   @id @default(cuid())
  shopId    String
  userId    String
  label     String
  cart      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, id])
}

model Notification {
  id        String              @id @default(cuid())
  shopId    String
  userId    String?
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(QUEUED)
  title     String
  message   String
  metadata  Json?
  createdAt DateTime            @default(now())
  readAt    DateTime?

  shop Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([shopId, id])
  @@index([userId, status])
}

model ShopPaymentConfig {
  id                   String   @id @default(cuid())
  shopId               String   @unique
  paystackPublicKey    String?
  paystackSecretKeyRef String?
  momoProvider         String?  @default("Paystack")
  allowCash            Boolean  @default(true)
  allowCard            Boolean  @default(true)
  allowMomo            Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  shopId     String?
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  shop Shop? @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([shopId, id])
  @@index([userId, createdAt])
}
