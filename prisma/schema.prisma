generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum PlanTier {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
  DESIGNER
  INVENTORY_CLERK
  ACCOUNTANT
  VIEWER
  SUPPLIER
}

enum AttributeType {
  TEXT
  NUMBER
  SELECT
}

enum ProductCondition {
  NEW
  USED
  REFURBISHED
}

enum OrderStatus {
  PENDING
  IN_PRODUCTION
  READY
  COMPLETED
  CANCELLED
}

enum OrderChannel {
  POS
  ONLINE
}

enum PaymentMethod {
  CASH
  CARD
  MOMO
  STORE_CREDIT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum NotificationChannel {
  IN_APP
  SMS
  WHATSAPP
  EMAIL
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  READ
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum DebtStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
  WRITTEN_OFF
}

enum InstallmentStatus {
  SCHEDULED
  PAID
  LATE
  CANCELLED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum DesignJobStatus {
  DRAFT
  READY
  SENT_TO_MACHINE
  ARCHIVED
}

enum SupplierOrderStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum NetworkLinkStatus {
  REQUESTED
  ACTIVE
  BLOCKED
}

enum NetworkOrderStatus {
  REQUESTED
  ACCEPTED
  FULFILLED
  CANCELLED
}

enum ClosingStatus {
  DRAFT
  BALANCED
  VARIANCE
  APPROVED
}

enum ShopVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum DeliveryStatus {
  NOT_REQUIRED
  REQUESTED
  OUT_FOR_DELIVERY
  DELIVERED
  VERIFIED
}

enum PhoneVerificationPurpose {
  BUYER_LOGIN
  BUYER_PASSWORD_RESET
  STAFF_PASSWORD_RESET
  PICKUP_VERIFY
  DELIVERY_VERIFY
}

model Shop {
  id                         String                 @id @default(cuid())
  name                       String
  slug                       String                 @unique
  logoUrl                    String?
  primaryColor               String                 @default("#0f766e")
  secondaryColor             String                 @default("#f97316")
  planTier                   PlanTier               @default(BASIC)
  isActive                   Boolean                @default(true)
  city                       String?
  country                    String?                @default("Ghana")
  currency                   String                 @default("GHS")
  publicOrderingEnabled      Boolean                @default(true)
  storefrontEnabled          Boolean                @default(true)
  cashOrderHoldMinutes       Int                    @default(120)
  billingCycle               BillingCycle           @default(MONTHLY)
  subscriptionStatus         SubscriptionStatus     @default(TRIAL)
  monthlyPrice               Decimal?               @db.Decimal(12, 2)
  yearlyPrice                Decimal?               @db.Decimal(12, 2)
  subscriptionRenewalAt      DateTime?
  networkCode                String?                @unique
  staffLoginId               String?                @unique
  verificationStatus         ShopVerificationStatus @default(PENDING)
  legalBusinessName          String?
  businessRegistrationNumber String?
  taxIdentificationNumber    String?
  ownerGovernmentId          String?
  credentialContactName      String?
  credentialPhone            String?
  credentialEmail            String?
  credentialAddress          String?
  credentialDocumentUrl      String?
  verifiedAt                 DateTime?
  verifiedById               String?
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  users                 User[]
  categories            Category[]
  attributeTemplates    AttributeTemplate[]
  products              Product[]
  customers             Customer[]
  orders                Order[]
  auditLogs             AuditLog[]
  invites               InviteToken[]
  announcements         Announcement[]
  holds                 SaleHold[]
  notifications         Notification[]
  paymentConfig         ShopPaymentConfig?
  debts                 Debt[]
  customerMessages      CustomerMessage[]
  customerThreads       CustomerThread[]
  designJobs            DesignJob[]
  suppliers             Supplier[]
  supplierOrders        SupplierOrder[]
  dailyClosings         DailyClosing[]
  networkLinksSent      ShopNetworkLink[]   @relation("NetworkRequester")
  networkLinksReceived  ShopNetworkLink[]   @relation("NetworkPartner")
  networkOrdersSent     ShopNetworkOrder[]  @relation("NetworkOrderRequester")
  networkOrdersReceived ShopNetworkOrder[]  @relation("NetworkOrderPartner")
  productReviews        ProductReview[]
  verifiedBy            User?               @relation("ShopVerifiedBy", fields: [verifiedById], references: [id])

  @@index([isActive, planTier])
  @@index([subscriptionStatus, subscriptionRenewalAt])
  @@index([networkCode])
  @@index([staffLoginId])
  @@index([verificationStatus])
}

model User {
  id               String    @id @default(cuid())
  shopId           String?
  email            String    @unique
  passwordHash     String
  name             String
  phone            String?
  role             Role
  isActive         Boolean   @default(true)
  failedLoginCount Int       @default(0)
  lockUntil        DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  shop                   Shop?                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  auditLogs              AuditLog[]
  invitesSent            InviteToken[]           @relation("InviteCreatedBy")
  passwordResets         PasswordResetToken[]
  announcementDismissals AnnouncementDismissal[]
  processedOrders        Order[]                 @relation("OrderProcessedBy")
  notifications          Notification[]
  supplierPortal         Supplier?               @relation("SupplierPortalUser")
  supplierOrdersCreated  SupplierOrder[]         @relation("SupplierOrderCreatedBy")
  dailyClosings          DailyClosing[]          @relation("ClosingClosedBy")
  shopsVerified          Shop[]                  @relation("ShopVerifiedBy")
  phoneVerificationCodes PhoneVerificationCode[]

  @@index([shopId, id])
  @@index([role, isActive])
}

model Category {
  id                  String   @id @default(cuid())
  shopId              String
  name                String
  parentCategoryId    String?
  attributeTemplateId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  parent            Category?          @relation("CategoryTree", fields: [parentCategoryId], references: [id])
  children          Category[]         @relation("CategoryTree")
  attributeTemplate AttributeTemplate? @relation(fields: [attributeTemplateId], references: [id])
  products          Product[]

  @@unique([shopId, name])
  @@index([shopId, id])
}

model AttributeTemplate {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop       Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  fields     AttributeField[]
  categories Category[]

  @@unique([shopId, name])
  @@index([shopId, id])
}

model AttributeField {
  id         String        @id @default(cuid())
  templateId String
  name       String
  type       AttributeType
  options    Json?
  required   Boolean       @default(false)

  template AttributeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Product {
  id                  String           @id @default(cuid())
  shopId              String
  categoryId          String
  name                String
  description         String?
  brand               String?
  condition           ProductCondition @default(NEW)
  isPersonalizable    Boolean          @default(false)
  isService           Boolean          @default(false)
  isRentable          Boolean          @default(false)
  productType         String?
  sportType           String?
  teamName            String?
  sizeGuide           Json             @default("[]")
  basePrice           Decimal          @db.Decimal(12, 2)
  dailyRentalRate     Decimal?         @db.Decimal(12, 2)
  serviceDurationMins Int?
  lowStockThreshold   Int              @default(5)
  images              Json             @default("[]")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]
  reviews  ProductReview[]

  @@index([shopId, id])
  @@index([shopId, categoryId])
  @@index([shopId, condition])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  sku           String   @unique
  attributes    Json     @default("{}")
  stockQty      Int      @default(0)
  priceOverride Decimal? @db.Decimal(12, 2)
  barcode       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product            Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems         OrderItem[]
  supplierOrderItems SupplierOrderItem[]
  networkOrderItems  ShopNetworkOrderItem[]

  @@index([productId, id])
  @@index([sku])
}

model Customer {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  email         String?
  phone         String?
  group         String   @default("Retail")
  notes         String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop       Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders     Order[]
  debts      Debt[]
  messages   CustomerMessage[]
  threads    CustomerThread[]
  designJobs DesignJob[]

  @@index([shopId, id])
  @@index([shopId, phone])
  @@index([shopId, email])
}

model BuyerAccount {
  id              String    @id @default(cuid())
  email           String?   @unique
  phone           String    @unique
  name            String
  passwordHash    String?
  phoneVerifiedAt DateTime?
  lastLoginAt     DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders                 Order[]
  reviews                ProductReview[]
  phoneVerificationCodes PhoneVerificationCode[]

  @@index([phone, isActive])
  @@index([email])
}

model Order {
  id             String       @id @default(cuid())
  shopId         String
  customerId     String?
  buyerId        String?
  processedById  String?
  status         OrderStatus  @default(PENDING)
  channel        OrderChannel @default(POS)
  totalAmount    Decimal      @db.Decimal(12, 2)
  discountAmount Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal      @default(0) @db.Decimal(12, 2)
  notes          String?
  rush           Boolean      @default(false)
  receiptNumber  String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  shop               Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer           Customer?       @relation(fields: [customerId], references: [id])
  buyer              BuyerAccount?   @relation(fields: [buyerId], references: [id])
  processedBy        User?           @relation("OrderProcessedBy", fields: [processedById], references: [id])
  items              OrderItem[]
  payments           Payment[]
  debts              Debt[]
  designJobs         DesignJob[]
  cashHoldExpiresAt  DateTime?
  publicAccessToken  String?         @unique
  paystackReference  String?
  fulfillmentType    FulfillmentType @default(PICKUP)
  deliveryStatus     DeliveryStatus  @default(NOT_REQUIRED)
  deliveryAddress    String?
  deliveryCity       String?
  deliveryArea       String?
  deliveryNotes      String?
  deliveryFee        Decimal         @default(0) @db.Decimal(12, 2)
  pickupCodeHash     String?
  pickupCodeLast4    String?
  pickupVerifiedAt   DateTime?
  deliveryVerifiedAt DateTime?
  customerVerifiedAt DateTime?

  @@index([shopId, id])
  @@index([shopId, status])
  @@index([shopId, createdAt])
  @@index([publicAccessToken])
  @@index([buyerId, createdAt])
}

model OrderItem {
  id                  String  @id @default(cuid())
  orderId             String
  productVariantId    String
  quantity            Int
  unitPrice           Decimal @db.Decimal(12, 2)
  personalizationData Json?

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  method            PaymentMethod
  amount            Decimal       @db.Decimal(12, 2)
  status            PaymentStatus @default(PENDING)
  providerReference String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model InviteToken {
  id          String    @id @default(cuid())
  shopId      String
  email       String
  role        Role
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  shop      Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdBy User @relation("InviteCreatedBy", fields: [createdById], references: [id])

  @@index([shopId, id])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PhoneVerificationCode {
  id        String                   @id @default(cuid())
  userId    String?
  buyerId   String?
  phone     String
  purpose   PhoneVerificationPurpose
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int                      @default(0)
  createdAt DateTime                 @default(now())

  user  User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  buyer BuyerAccount? @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([phone, purpose, createdAt])
  @@index([userId, purpose])
  @@index([buyerId, purpose])
}

model ProductReview {
  id         String   @id @default(cuid())
  shopId     String
  productId  String
  buyerId    String
  rating     Int
  comment    String?
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop    Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer   BuyerAccount @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([productId, buyerId])
  @@index([shopId, createdAt])
  @@index([buyerId, createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  shopId    String?
  title     String
  body      String
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())

  shop       Shop?                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  dismissals AnnouncementDismissal[]
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  dismissedAt    DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

model SaleHold {
  id        String   @id @default(cuid())
  shopId    String
  userId    String
  label     String
  cart      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, id])
}

model Notification {
  id        String              @id @default(cuid())
  shopId    String
  userId    String?
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(QUEUED)
  title     String
  message   String
  metadata  Json?
  createdAt DateTime            @default(now())
  readAt    DateTime?

  shop Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([shopId, id])
  @@index([userId, status])
}

model Debt {
  id              String     @id @default(cuid())
  shopId          String
  customerId      String
  orderId         String?
  principalAmount Decimal    @db.Decimal(12, 2)
  paidAmount      Decimal    @default(0) @db.Decimal(12, 2)
  status          DebtStatus @default(OPEN)
  dueDate         DateTime
  notes           String?
  reminderCount   Int        @default(0)
  lastReminderAt  DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  shop         Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id])
  order        Order?            @relation(fields: [orderId], references: [id])
  installments DebtInstallment[]

  @@index([shopId, status])
  @@index([customerId, dueDate])
  @@index([orderId])
}

model DebtInstallment {
  id        String            @id @default(cuid())
  debtId    String
  amount    Decimal           @db.Decimal(12, 2)
  dueDate   DateTime
  paidAt    DateTime?
  status    InstallmentStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId, dueDate])
}

model DailyClosing {
  id             String        @id @default(cuid())
  shopId         String
  closedById     String
  businessDate   DateTime      @db.Date
  openingFloat   Decimal       @default(0) @db.Decimal(12, 2)
  expectedCash   Decimal       @default(0) @db.Decimal(12, 2)
  manualCash     Decimal       @default(0) @db.Decimal(12, 2)
  cashDifference Decimal       @default(0) @db.Decimal(12, 2)
  expectedCard   Decimal       @default(0) @db.Decimal(12, 2)
  expectedMomo   Decimal       @default(0) @db.Decimal(12, 2)
  creditSales    Decimal       @default(0) @db.Decimal(12, 2)
  totalSales     Decimal       @default(0) @db.Decimal(12, 2)
  expenses       Decimal       @default(0) @db.Decimal(12, 2)
  refunds        Decimal       @default(0) @db.Decimal(12, 2)
  orderCount     Int           @default(0)
  status         ClosingStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  shop     Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  closedBy User @relation("ClosingClosedBy", fields: [closedById], references: [id])

  @@unique([shopId, businessDate])
  @@index([shopId, status])
  @@index([closedById, createdAt])
}

model CustomerMessage {
  id                String              @id @default(cuid())
  shopId            String
  customerId        String?
  channel           NotificationChannel
  direction         MessageDirection    @default(OUTBOUND)
  status            NotificationStatus  @default(QUEUED)
  recipientName     String?
  recipientPhone    String?
  recipientEmail    String?
  subject           String?
  body              String
  providerReference String?
  metadata          Json?
  createdAt         DateTime            @default(now())

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([shopId, createdAt])
  @@index([customerId, createdAt])
  @@index([channel, status])
}

model CustomerThread {
  id         String   @id @default(cuid())
  shopId     String
  customerId String?
  subject    String
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop     Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id])
  messages ChatMessage[]

  @@index([shopId, status])
  @@index([customerId, updatedAt])
}

model ChatMessage {
  id         String    @id @default(cuid())
  threadId   String
  senderType String
  senderName String
  body       String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  thread CustomerThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model DesignJob {
  id             String          @id @default(cuid())
  shopId         String
  customerId     String?
  orderId        String?
  title          String
  canvasJson     Json            @default("{}")
  machineProfile String?
  exportFormat   String?         @default("SVG")
  status         DesignJobStatus @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
  order    Order?    @relation(fields: [orderId], references: [id])

  @@index([shopId, status])
  @@index([customerId, createdAt])
}

model Supplier {
  id           String   @id @default(cuid())
  shopId       String
  portalUserId String?  @unique
  name         String
  contactName  String?
  email        String?
  phone        String?
  categories   String?
  paymentTerms String?
  leadTimeDays Int      @default(7)
  rating       Int      @default(5)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  portalUser     User?           @relation("SupplierPortalUser", fields: [portalUserId], references: [id], onDelete: SetNull)
  supplierOrders SupplierOrder[]

  @@index([shopId, isActive])
  @@index([portalUserId])
}

model SupplierOrder {
  id                String              @id @default(cuid())
  shopId            String
  supplierId        String
  createdById       String?
  status            SupplierOrderStatus @default(DRAFT)
  orderNumber       String              @unique
  expectedAt        DateTime?
  totalAmount       Decimal             @default(0) @db.Decimal(12, 2)
  supplierReference String?
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  shop      Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier  Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy User?               @relation("SupplierOrderCreatedBy", fields: [createdById], references: [id])
  items     SupplierOrderItem[]

  @@index([shopId, status])
  @@index([supplierId, createdAt])
}

model SupplierOrderItem {
  id               String  @id @default(cuid())
  supplierOrderId  String
  productVariantId String?
  description      String
  quantity         Int
  unitCost         Decimal @default(0) @db.Decimal(12, 2)
  receivedQty      Int     @default(0)

  supplierOrder  SupplierOrder   @relation(fields: [supplierOrderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@index([supplierOrderId])
  @@index([productVariantId])
}

model ShopNetworkLink {
  id              String            @id @default(cuid())
  requesterShopId String
  partnerShopId   String
  status          NetworkLinkStatus @default(REQUESTED)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  requesterShop Shop @relation("NetworkRequester", fields: [requesterShopId], references: [id], onDelete: Cascade)
  partnerShop   Shop @relation("NetworkPartner", fields: [partnerShopId], references: [id], onDelete: Cascade)

  @@unique([requesterShopId, partnerShopId])
  @@index([partnerShopId, status])
}

model ShopNetworkOrder {
  id              String             @id @default(cuid())
  requesterShopId String
  partnerShopId   String
  status          NetworkOrderStatus @default(REQUESTED)
  orderNumber     String             @unique
  totalAmount     Decimal            @default(0) @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  requesterShop Shop                   @relation("NetworkOrderRequester", fields: [requesterShopId], references: [id], onDelete: Cascade)
  partnerShop   Shop                   @relation("NetworkOrderPartner", fields: [partnerShopId], references: [id], onDelete: Cascade)
  items         ShopNetworkOrderItem[]

  @@index([requesterShopId, status])
  @@index([partnerShopId, status])
}

model ShopNetworkOrderItem {
  id               String  @id @default(cuid())
  networkOrderId   String
  productVariantId String?
  description      String
  quantity         Int
  unitPrice        Decimal @default(0) @db.Decimal(12, 2)

  networkOrder   ShopNetworkOrder @relation(fields: [networkOrderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant?  @relation(fields: [productVariantId], references: [id])

  @@index([networkOrderId])
  @@index([productVariantId])
}

model ShopPaymentConfig {
  id                        String   @id @default(cuid())
  shopId                    String   @unique
  paystackPublicKey         String?
  paystackSecretKeyRef      String?
  paystackSubaccountCode    String?
  paystackTransactionCharge Int?
  paystackChargeBearer      String?  @default("subaccount")
  settlementBank            String?
  settlementAccount         String?
  settlementAccountName     String?
  shopMomoNumber            String?
  shopMomoNetwork           String?
  momoProvider              String?  @default("Paystack")
  allowCash                 Boolean  @default(true)
  allowCard                 Boolean  @default(true)
  allowMomo                 Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  shopId     String?
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  shop Shop? @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([shopId, id])
  @@index([userId, createdAt])
}
