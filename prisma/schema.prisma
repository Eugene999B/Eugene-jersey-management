generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum PlanTier {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum Role {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
  DESIGNER
  INVENTORY_CLERK
  ACCOUNTANT
  VIEWER
}

enum AttributeType {
  TEXT
  NUMBER
  SELECT
}

enum ProductCondition {
  NEW
  USED
  REFURBISHED
}

enum OrderStatus {
  PENDING
  IN_PRODUCTION
  READY
  COMPLETED
  CANCELLED
}

enum OrderChannel {
  POS
  ONLINE
}

enum PaymentMethod {
  CASH
  CARD
  MOMO
  STORE_CREDIT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum NotificationChannel {
  IN_APP
  SMS
  WHATSAPP
  EMAIL
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  READ
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum DebtStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
  WRITTEN_OFF
}

enum InstallmentStatus {
  SCHEDULED
  PAID
  LATE
  CANCELLED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum DesignJobStatus {
  DRAFT
  READY
  SENT_TO_MACHINE
  ARCHIVED
}

model Shop {
  id                    String             @id @default(cuid())
  name                  String
  slug                  String             @unique
  logoUrl               String?
  primaryColor          String             @default("#0f766e")
  secondaryColor        String             @default("#f97316")
  planTier              PlanTier           @default(BASIC)
  isActive              Boolean            @default(true)
  city                  String?
  country               String?            @default("Ghana")
  currency              String             @default("GHS")
  publicOrderingEnabled Boolean            @default(true)
  storefrontEnabled     Boolean            @default(true)
  cashOrderHoldMinutes  Int                @default(120)
  billingCycle          BillingCycle       @default(MONTHLY)
  subscriptionStatus    SubscriptionStatus @default(TRIAL)
  monthlyPrice          Decimal?           @db.Decimal(12, 2)
  yearlyPrice           Decimal?           @db.Decimal(12, 2)
  subscriptionRenewalAt DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  users              User[]
  categories         Category[]
  attributeTemplates AttributeTemplate[]
  products           Product[]
  customers          Customer[]
  orders             Order[]
  auditLogs          AuditLog[]
  invites            InviteToken[]
  announcements      Announcement[]
  holds              SaleHold[]
  notifications      Notification[]
  paymentConfig      ShopPaymentConfig?
  debts              Debt[]
  customerMessages   CustomerMessage[]
  customerThreads    CustomerThread[]
  designJobs         DesignJob[]

  @@index([isActive, planTier])
  @@index([subscriptionStatus, subscriptionRenewalAt])
}

model User {
  id               String    @id @default(cuid())
  shopId           String?
  email            String    @unique
  passwordHash     String
  name             String
  phone            String?
  role             Role
  isActive         Boolean   @default(true)
  failedLoginCount Int       @default(0)
  lockUntil        DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  shop                   Shop?                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  auditLogs              AuditLog[]
  invitesSent            InviteToken[]           @relation("InviteCreatedBy")
  passwordResets         PasswordResetToken[]
  announcementDismissals AnnouncementDismissal[]
  processedOrders        Order[]                 @relation("OrderProcessedBy")
  notifications          Notification[]

  @@index([shopId, id])
  @@index([role, isActive])
}

model Category {
  id                  String   @id @default(cuid())
  shopId              String
  name                String
  parentCategoryId    String?
  attributeTemplateId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  parent            Category?          @relation("CategoryTree", fields: [parentCategoryId], references: [id])
  children          Category[]         @relation("CategoryTree")
  attributeTemplate AttributeTemplate? @relation(fields: [attributeTemplateId], references: [id])
  products          Product[]

  @@unique([shopId, name])
  @@index([shopId, id])
}

model AttributeTemplate {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop       Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  fields     AttributeField[]
  categories Category[]

  @@unique([shopId, name])
  @@index([shopId, id])
}

model AttributeField {
  id         String        @id @default(cuid())
  templateId String
  name       String
  type       AttributeType
  options    Json?
  required   Boolean       @default(false)

  template AttributeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model Product {
  id                  String           @id @default(cuid())
  shopId              String
  categoryId          String
  name                String
  description         String?
  brand               String?
  condition           ProductCondition @default(NEW)
  isPersonalizable    Boolean          @default(false)
  isService           Boolean          @default(false)
  isRentable          Boolean          @default(false)
  basePrice           Decimal          @db.Decimal(12, 2)
  dailyRentalRate     Decimal?         @db.Decimal(12, 2)
  serviceDurationMins Int?
  lowStockThreshold   Int              @default(5)
  images              Json             @default("[]")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]

  @@index([shopId, id])
  @@index([shopId, categoryId])
  @@index([shopId, condition])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  sku           String   @unique
  attributes    Json     @default("{}")
  stockQty      Int      @default(0)
  priceOverride Decimal? @db.Decimal(12, 2)
  barcode       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId, id])
  @@index([sku])
}

model Customer {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  email         String?
  phone         String?
  group         String   @default("Retail")
  notes         String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop       Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders     Order[]
  debts      Debt[]
  messages   CustomerMessage[]
  threads    CustomerThread[]
  designJobs DesignJob[]

  @@index([shopId, id])
  @@index([shopId, phone])
  @@index([shopId, email])
}

model Order {
  id             String       @id @default(cuid())
  shopId         String
  customerId     String?
  processedById  String?
  status         OrderStatus  @default(PENDING)
  channel        OrderChannel @default(POS)
  totalAmount    Decimal      @db.Decimal(12, 2)
  discountAmount Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal      @default(0) @db.Decimal(12, 2)
  notes          String?
  rush           Boolean      @default(false)
  receiptNumber  String       @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  shop              Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer          Customer?   @relation(fields: [customerId], references: [id])
  processedBy       User?       @relation("OrderProcessedBy", fields: [processedById], references: [id])
  items             OrderItem[]
  payments          Payment[]
  debts             Debt[]
  designJobs        DesignJob[]
  cashHoldExpiresAt DateTime?
  publicAccessToken String?     @unique
  paystackReference String?

  @@index([shopId, id])
  @@index([shopId, status])
  @@index([shopId, createdAt])
  @@index([publicAccessToken])
}

model OrderItem {
  id                  String  @id @default(cuid())
  orderId             String
  productVariantId    String
  quantity            Int
  unitPrice           Decimal @db.Decimal(12, 2)
  personalizationData Json?

  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  method            PaymentMethod
  amount            Decimal       @db.Decimal(12, 2)
  status            PaymentStatus @default(PENDING)
  providerReference String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model InviteToken {
  id          String    @id @default(cuid())
  shopId      String
  email       String
  role        Role
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  shop      Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdBy User @relation("InviteCreatedBy", fields: [createdById], references: [id])

  @@index([shopId, id])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String   @id @default(cuid())
  shopId    String?
  title     String
  body      String
  isGlobal  Boolean  @default(false)
  createdAt DateTime @default(now())

  shop       Shop?                   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  dismissals AnnouncementDismissal[]
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  dismissedAt    DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

model SaleHold {
  id        String   @id @default(cuid())
  shopId    String
  userId    String
  label     String
  cart      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, id])
}

model Notification {
  id        String              @id @default(cuid())
  shopId    String
  userId    String?
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(QUEUED)
  title     String
  message   String
  metadata  Json?
  createdAt DateTime            @default(now())
  readAt    DateTime?

  shop Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([shopId, id])
  @@index([userId, status])
}

model Debt {
  id              String     @id @default(cuid())
  shopId          String
  customerId      String
  orderId         String?
  principalAmount Decimal    @db.Decimal(12, 2)
  paidAmount      Decimal    @default(0) @db.Decimal(12, 2)
  status          DebtStatus @default(OPEN)
  dueDate         DateTime
  notes           String?
  reminderCount   Int        @default(0)
  lastReminderAt  DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  shop         Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id])
  order        Order?            @relation(fields: [orderId], references: [id])
  installments DebtInstallment[]

  @@index([shopId, status])
  @@index([customerId, dueDate])
  @@index([orderId])
}

model DebtInstallment {
  id        String            @id @default(cuid())
  debtId    String
  amount    Decimal           @db.Decimal(12, 2)
  dueDate   DateTime
  paidAt    DateTime?
  status    InstallmentStatus @default(SCHEDULED)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId, dueDate])
}

model CustomerMessage {
  id                String              @id @default(cuid())
  shopId            String
  customerId        String?
  channel           NotificationChannel
  direction         MessageDirection    @default(OUTBOUND)
  status            NotificationStatus  @default(QUEUED)
  recipientName     String?
  recipientPhone    String?
  recipientEmail    String?
  subject           String?
  body              String
  providerReference String?
  metadata          Json?
  createdAt         DateTime            @default(now())

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([shopId, createdAt])
  @@index([customerId, createdAt])
  @@index([channel, status])
}

model CustomerThread {
  id         String   @id @default(cuid())
  shopId     String
  customerId String?
  subject    String
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop     Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id])
  messages ChatMessage[]

  @@index([shopId, status])
  @@index([customerId, updatedAt])
}

model ChatMessage {
  id         String    @id @default(cuid())
  threadId   String
  senderType String
  senderName String
  body       String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  thread CustomerThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model DesignJob {
  id             String          @id @default(cuid())
  shopId         String
  customerId     String?
  orderId        String?
  title          String
  canvasJson     Json            @default("{}")
  machineProfile String?
  exportFormat   String?         @default("SVG")
  status         DesignJobStatus @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
  order    Order?    @relation(fields: [orderId], references: [id])

  @@index([shopId, status])
  @@index([customerId, createdAt])
}

model ShopPaymentConfig {
  id                   String   @id @default(cuid())
  shopId               String   @unique
  paystackPublicKey    String?
  paystackSecretKeyRef String?
  momoProvider         String?  @default("Paystack")
  allowCash            Boolean  @default(true)
  allowCard            Boolean  @default(true)
  allowMomo            Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  shopId     String?
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  shop Shop? @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@index([shopId, id])
  @@index([userId, createdAt])
}
